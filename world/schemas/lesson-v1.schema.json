{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://niuma.city/schemas/lesson-v1.json",
  "title": "NIUMA CITY Academy Lesson Schema v1",
  "description": "Machine-readable lesson format for Academy District onboarding and learning",
  "type": "object",
  "required": ["id", "version", "title", "description", "difficulty", "estimatedTime", "prerequisites", "actions", "proof", "graduation"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^L-[0-9]{4}$",
      "description": "Unique lesson identifier, e.g., L-0001"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version, current is 1"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Human-readable lesson title"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "Brief explanation of what the lesson teaches"
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"],
      "description": "Lesson difficulty level"
    },
    "estimatedTime": {
      "type": "string",
      "pattern": "^[0-9]+ (min|hour|hours)$",
      "description": "Estimated completion time, e.g., '30 min', '2 hours'"
    },
    "district": {
      "type": "string",
      "default": "academy",
      "description": "District slug where this lesson belongs"
    },
    "prerequisites": {
      "type": "object",
      "required": ["lessons", "skills", "resources"],
      "properties": {
        "lessons": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^L-[0-9]{4}$"
          },
          "description": "List of lesson IDs that must be completed first"
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Required skills or knowledge"
        },
        "resources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "url"],
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "type": { "type": "string", "enum": ["doc", "video", "code", "tool"] }
            }
          },
          "description": "Required resources to complete the lesson"
        }
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step", "description", "type"],
        "properties": {
          "step": {
            "type": "integer",
            "minimum": 1,
            "description": "Step number in sequence"
          },
          "description": {
            "type": "string",
            "description": "What the learner should do"
          },
          "type": {
            "type": "string",
            "enum": ["read", "write", "code", "test", "submit", "verify"],
            "description": "Type of action required"
          },
          "resources": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Links or references for this step"
          },
          "expectedOutcome": {
            "type": "string",
            "description": "What successful completion looks like"
          }
        }
      }
    },
    "proof": {
      "type": "object",
      "required": ["type", "requirements"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["github_pr", "github_issue", "chain_tx", "test_pass", "manifest_entry"],
          "description": "Type of proof required"
        },
        "requirements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "description": "Specific requirements the proof must meet"
        },
        "validationScript": {
          "type": "string",
          "description": "Optional script or command to validate proof"
        }
      }
    },
    "graduation": {
      "type": "object",
      "required": ["outcome", "nextSteps"],
      "properties": {
        "outcome": {
          "type": "string",
          "description": "What the learner achieves by completing this lesson"
        },
        "rewards": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["credential", "role", "access", "reputation"] },
              "value": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "description": "Rewards or recognitions earned"
        },
        "nextSteps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "target"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["lesson", "quest", "role", "action"]
              },
              "target": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "description": "Recommended next actions after graduation"
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "relatedQuests": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^Q-[0-9]{4}$"
          }
        }
      }
    }
  }
}
